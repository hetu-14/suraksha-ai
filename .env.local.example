# Copy this file to .env.local and fill in what you need.
# Anything left blank => that feature runs in demo/fallback mode.

# ── Supabase (WhyMyBill live data) ─────────────────────────────
# Settings → API in your Supabase dashboard. The anon key is safe to expose.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ── SafeZone detector (CCTV) ───────────────────────────────────
# URL of the local Python detector (detector/detect.py). If unreachable,
# the SafeZone page falls back to a simulated feed automatically.
NEXT_PUBLIC_SAFEZONE_API=http://localhost:8000

# ── AutoNotify WhatsApp ────────────────────────────────────────
# Pick ONE provider. If none set, AutoNotify runs in demo (simulated) mode.
#
# Option A — CallMeBot (100% free, no account).
#   Each recipient adds +34 684 72 39 62 on WhatsApp and sends
#   "I allow callmebot to send me messages" to get their apikey.
#   Then list them here as JSON: [{ "phone": "+91...", "apikey": "123456" }]
# CALLMEBOT_RECIPIENTS=[{"phone":"+9198XXXXXXXX","apikey":"123456"}]
#
# Option B — Twilio WhatsApp Sandbox (free trial).
#   Recipients first send "join <your-code>" to the Twilio sandbox number.
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# WHATSAPP_RECIPIENTS=["+9198XXXXXXXX","+9199XXXXXXXX"]
