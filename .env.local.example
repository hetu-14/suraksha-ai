# Copy this file to .env.local and fill in what you need.
# Anything left blank => that feature runs in demo/fallback mode.

# ── Supabase (WhyMyBill live data) ─────────────────────────────
# Settings → API in your Supabase dashboard. The anon key is safe to expose.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ── SafeZone detector (CCTV) ───────────────────────────────────
# URL of the local Python detector (detector/detect.py). If unreachable,
# the SafeZone page falls back to a simulated feed automatically.
NEXT_PUBLIC_SAFEZONE_API=http://localhost:8000

# ── AutoNotify WhatsApp ────────────────────────────────────────
# Pick ONE provider. If none set, AutoNotify runs in demo (simulated) mode.
#
# ✅ Option A — GREEN-API (RECOMMENDED, free & actually works).
#   1) Sign up free at https://green-api.com  → create a Developer instance
#   2) Copy its idInstance + apiTokenInstance
#   3) In the console, scan the QR with your phone (WhatsApp → Linked devices)
#   4) List up to 3 recipient numbers (free-tier limit). Sends to ANY number,
#      no opt-in needed. Numbers with country code, no "+".
# GREENAPI_ID_INSTANCE=1101000001
# GREENAPI_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# WHATSAPP_RECIPIENTS=["919876543210","919812345678"]
# GREENAPI_BASE=https://api.green-api.com   # only if your console shows a custom apiUrl
#
# Option B — Twilio WhatsApp Sandbox (free trial). Recipients "join <code>" once.
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# WHATSAPP_RECIPIENTS=["+9198XXXXXXXX"]
#
# Option C — CallMeBot (no account but flaky; only messages numbers that registered).
# CALLMEBOT_RECIPIENTS=[{"phone":"+9198XXXXXXXX","apikey":"123456"}]
